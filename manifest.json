{
  "manifest_version": 3,
  "name": "Liked & Loaded — Play liked by artist (for YouTube Music)",
  "short_name": "Liked & Loaded",
  "version": "0.4.0",
  "description": "Shuffle-play songs you liked by artist (a button on the artist page) or several at once (an artist picker next to the search bar).",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["src/main-world.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["src/content.js"],
      "css": ["src/inject.css"],
      "run_at": "document_end",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/mark.png"],
      "matches": ["https://music.youtube.com/*"]
    }
  ]
}
